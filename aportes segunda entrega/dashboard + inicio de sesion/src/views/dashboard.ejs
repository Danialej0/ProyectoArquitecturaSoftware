<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FerroAllamano - Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
</head>
<body>
    <div class="main-wrapper">
        <aside class="sidebar">
            <div class="sidebar-top">
                <div class="logo-container">
                    <span class="logo-main">FERROALLAMANO</span>
                    <span class="logo-sub">dashboard</span>
                </div>
                <nav class="sidebar-nav">
                    <a href="#" class="nav-item">
                        <i class="fa-solid fa-box-open"></i>
                        <span>Productos</span>
                    </a>
                    <a href="#" class="nav-item active">
                        <i class="fa-solid fa-money-bill-transfer"></i>
                        <span>Módulo de Ventas</span>
                    </a>
                </nav>
            </div>
            <div class="sidebar-bottom">
                <button class="btn-sidebar-alt">+ Nueva cliente</button>
                <button class="btn-sidebar-alt">+ Nueva Venta</button>
            </div>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div class="topbar-search-placeholder"></div>
                <div class="topbar-actions">
                    <i class="fa-regular fa-bell icon-topbar"></i>
                    <i class="fa-regular fa-circle-user icon-topbar user-avatar"></i>
                </div>
            </header>

            <div class="dashboard-area">
                <div class="content-header">
                    <div class="content-header-titles">
                        <h1>Resumen Diario</h1>
                        <p><%= data.resumenDiario.metricaPrincipal %></p>
                    </div>
                    <div class="date-picker-placeholder">
                        <i class="fa-regular fa-calendar-days"></i>
                        <span><%= data.resumenDiario.fecha %></span>
                    </div>
                </div>

                <section class="stats-grid">
                    <% data.cards.forEach(function(card) { %>
                        <div class="stat-card">
                            <div class="card-top-row">
                                <i class="<%= card.iconClass %> icon-card-stat"></i>
                                <div class="trend-pill <%= card.trendClass %>">
                                    <span><%= card.trend %></span>
                                </div>
                            </div>
                            <div class="card-main-content">
                                <p class="card-title-stat"><%= card.title %></p>
                                <p class="card-value-stat"><%= card.value %></p>
                            </div>
                            <p class="card-vs-yesterday">vs. ayer (<%= card.vsAyer %>)</p>
                        </div>
                    <% }); %>
                </section>

                <section class="chart-section">
                    <div class="chart-card">
                        <p class="chart-title">Top Categorías</p>
                        <div class="chart-bars-list">
                            <% data.categorias.forEach(function(cat) { %>
                                <div class="chart-bar-item">
                                    <div class="bar-label">
                                        <span class="color-dot" style="background-color: <%= cat.color %>;"></span>
                                        <span class="category-name"><%= cat.name %></span>
                                    </div>
                                    <div class="bar-container-wrapper">
                                        <div class="bar-container-bg">
                                            <div class="bar-fill" style="width: <%= cat.percentage %>%; background-color: <%= cat.color %>;"></div>
                                        </div>
                                        <span class="category-percentage"><%= cat.percentage %>%</span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>
</body>
</html>